# ---------------------------------------------------------------------------
# Server-side environment variables for the AI proxy (api/chat.js).
# Copy to ".env" for local `vercel dev`, and set the SAME values in the Vercel
# dashboard (Project → Settings → Environment Variables) for production.
#
# NEVER commit a real value. ".env" is gitignored; only this example is tracked.
# ---------------------------------------------------------------------------

# REQUIRED. The Cerebras API key. Used ONLY by the server function — it is never
# shipped to any browser or app binary.
CEREBRAS_API_KEY=your-cerebras-key-here

# OPTIONAL. Comma-separated list of browser origins allowed to call /api/chat.
# Leave empty to use the built-in same-site + localhost + capacitor allowance.
# Example: https://your-app.vercel.app,https://anchor.example.com
ALLOWED_ORIGINS=