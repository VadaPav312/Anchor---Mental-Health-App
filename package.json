{
  "name": "anchor",
  "version": "1.0.0",
  "description": "Anchor — a mental-wellness companion paired with a bedside Arduino sleep monitor. Compounding, deeply personal insight that reflects you back to yourself.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "bridge": "node server.js",
    "restart": "bash scripts/restart-bridge.sh",
    "deploy": "npx cap sync ios",
    "ios": "npx cap sync ios && npx cap open ios",
    "wire-google": "node scripts/wire-google.js",
    "demo": "bash scripts/demo-bridge.sh"
  },
  "keywords": [
    "wellness",
    "sleep",
    "arduino",
    "capacitor",
    "ios",
    "mental-health"
  ],
  "author": "flowstate",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-social-login": "^8.3.22",
    "@serialport/parser-readline": "^13.0.0",
    "express": "^5.2.1",
    "serialport": "^13.0.0"
  }
}
